PORT=4000
LOG_LEVEL=info

CHATWOOT_BASE_URL=https://your-chatwoot.example.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_TOKEN=replace_with_api_access_token
CHATWOOT_WEBHOOK_SECRET=replace_with_webhook_secret
CHATWOOT_SKIP_SIGNATURE_VERIFICATION=false
SKILLS_DIR=./skills
SKILLS_MIN_SCORE=0.45

ENABLE_AI_SKILL_MATCHING=true
ENABLE_AI_SKILL_RESPONSE=true
AI_SKILL_MIN_CONFIDENCE=0.65
AI_SKILL_MAX_CANDIDATES=20
AI_SKILL_RESPONSE_MAX_CHARS=420
ENABLE_AI_FAQ_CONFIRMATION=true
AI_FAQ_MIN_CONFIDENCE=0.7
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=6000

BUSINESS_HOURS_ENABLED=false
BUSINESS_TIMEZONE=America/Argentina/Buenos_Aires
BUSINESS_WORKING_DAYS=1,2,3,4,5
BUSINESS_START_TIME=09:00
BUSINESS_END_TIME=18:00
BUSINESS_HOURS_LABEL=lunes a viernes de 09:00 a 18:00
