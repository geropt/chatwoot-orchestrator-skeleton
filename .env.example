PORT=4000
LOG_LEVEL=info

# Chatwoot
CHATWOOT_BASE_URL=https://your-chatwoot.example.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_TOKEN=replace_with_api_access_token
CHATWOOT_WEBHOOK_SECRET=replace_with_webhook_secret
CHATWOOT_SKIP_SIGNATURE_VERIFICATION=false

# Skills
SKILLS_DIR=./skills

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Agente
AGENT_MAX_TURNS=8
AGENT_MAX_RETRIES=2
AGENT_MAX_TOOL_ITERATIONS=3
AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=1024

# Horario de soporte
SUPPORT_TIMEZONE=America/Argentina/Buenos_Aires
SUPPORT_BUSINESS_HOURS_JSON={"monday":[{"start":"08:30","end":"17:00"}],"tuesday":[{"start":"08:30","end":"17:00"}],"wednesday":[{"start":"08:30","end":"17:00"}],"thursday":[{"start":"08:30","end":"17:00"}],"friday":[{"start":"08:30","end":"17:00"}]}
SUPPORT_HOLIDAYS=
SUPPORT_EMERGENCY_PHONE=
